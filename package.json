{
  "name": "moderno",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Moderno — framework-agnostic, token-driven design system (React, Vue, Svelte, Solid)",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "docs": "pnpm --filter @moderno/docs dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.30.3"
}
